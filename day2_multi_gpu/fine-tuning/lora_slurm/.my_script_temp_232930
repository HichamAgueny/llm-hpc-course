# python "${PYTHON_FILE}" --config "${CONFIG_FILE}" checkpointer.output_dir="${OUTPUT_DIR}" output_dir="${LOGGING_DIR}" epochs=1

# Default execution
python "${PYTHON_FILE}" --config "${CONFIG_FILE}"

