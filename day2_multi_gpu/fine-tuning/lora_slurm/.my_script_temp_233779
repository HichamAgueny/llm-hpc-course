#!/bin/bash -e

# --- Suppress CUDA compat rm warnings ---
export APPTAINER_NO_COMPAT=1

# Flash Attention for efficiency
export USE_FLASH_ATTENTION=1

# Avoid CUDA memory fragmentation
#export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Set up variables to control distributed PyTorch training
export RANK=$SLURM_PROCID
export LOCAL_RANK=$SLURM_LOCALID
#export WORLD_SIZE=$SLURM_NPROCS
#export LOCAL_WORLD_SIZE=$SLURM_GPUS_PER_NODE

echo "Task ${SLURM_PROCID}: RANK=0, LOCAL_RANK=0, WORLD_SIZE = 4, LOCAL_WORLD_SIZE = 4"
echo "LOCAL_RANK: ${LOCAL_RANK}, CUDA_VISIBLE_DEVICES: ${CUDA_VISIBLE_DEVICES}"

# Run the fine-tuning script
# To override output dirs (optional):
# python "/workspace/recipes/distributed/lora_finetune_distributed.py" --config "/workspace/configs/qlora/llama3_1_8B_qlora_multi_device_alpaca_gpt4.yaml" checkpointer.output_dir="/workspace/results/checkpoints_out/llama3_q_8B_qlora_multi_device" output_dir="/workspace/results/lora_finetune_8B_output" epochs=1

# Default execution
python "/workspace/recipes/distributed/lora_finetune_distributed.py" --config "/workspace/configs/qlora/llama3_1_8B_qlora_multi_device_alpaca_gpt4.yaml" world_size=4 local_world_size=4

# Syntax of "tune run" command
#the flag --standalone is Useful when launching single-node, multi-worker job
